<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BeOnyx.dev</title>
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    :root {
      --black:  #000000;
      --silver: #b8b8c8;
      --ghost:  #2a2a3a;
      --trace:  #141420;
      --eng:    #505060;
      --dim:    #282830;
    }
    html, body { width:100%; height:100%; overflow:hidden; background:#000; }

    #scroller {
      width:100%; height:100vh;
      overflow-y:scroll; overflow-x:hidden;
      -webkit-overflow-scrolling:touch;
      scrollbar-width:none;
    }
    #scroller::-webkit-scrollbar { display:none; }

    #spacer { position:relative; }

    #stage {
      position:sticky; top:0;
      width:100%; height:100vh;
      overflow:hidden;
      display:flex; align-items:center; justify-content:center;
      background:#000;
    }

    #atmos { position:absolute; inset:0; width:100%; height:100%; pointer-events:none; z-index:0; }

    .edge { position:absolute; left:44px; right:44px; height:1px; background:linear-gradient(90deg,transparent 0%,var(--trace) 20%,var(--trace) 80%,transparent 100%); pointer-events:none; z-index:5; }
    .edge.top { top:32px; } .edge.bottom { bottom:32px; }

    .corner { position:absolute; width:12px; height:12px; pointer-events:none; z-index:5; }
    .corner::before,.corner::after { content:''; position:absolute; background:var(--ghost); }
    .corner.tl { top:24px; left:36px; } .corner.tl::before { width:1px; height:100%; } .corner.tl::after { width:100%; height:1px; }
    .corner.tr { top:24px; right:36px; } .corner.tr::before { width:1px; height:100%; right:0; } .corner.tr::after { width:100%; height:1px; }
    .corner.bl { bottom:24px; left:36px; } .corner.bl::before { width:1px; height:100%; bottom:0; top:auto; } .corner.bl::after { width:100%; height:1px; top:auto; bottom:0; }
    .corner.br { bottom:24px; right:36px; } .corner.br::before { width:1px; height:100%; right:0; bottom:0; top:auto; } .corner.br::after { width:100%; height:1px; top:auto; bottom:0; }

    .onyx-stage { perspective:3000px; position:absolute; inset:0; display:flex; align-items:center; justify-content:center; z-index:3; }

    .onyx-cube { width:180px; height:180px; position:relative; transform-style:preserve-3d; transition:transform 0.05s linear, opacity 0.15s ease; }
    .onyx-cube.breathing { animation:breathe 18s infinite ease-in-out; }
    @keyframes breathe {
      0%,100% { transform:rotateX(0deg)  rotateY(0deg)   scale(1);    }
      25%     { transform:rotateX(10deg) rotateY(90deg)  scale(1.03); }
      50%     { transform:rotateX(18deg) rotateY(180deg) scale(1);    }
      75%     { transform:rotateX(10deg) rotateY(270deg) scale(1.03); }
    }

    .face {
      position:absolute; width:180px; height:180px; background:#000;
      border:1px solid rgba(40,60,160,0.18);
      box-shadow:inset 0 0 30px #000;
      display:flex; flex-direction:column; align-items:center; justify-content:center;
      padding:24px; text-align:center;
      backface-visibility:hidden; -webkit-backface-visibility:hidden;
    }
    .face:nth-child(1){transform:rotateY(0deg)   translateZ(90px);}
    .face:nth-child(2){transform:rotateY(90deg)  translateZ(90px);}
    .face:nth-child(3){transform:rotateY(180deg) translateZ(90px);}
    .face:nth-child(4){transform:rotateY(-90deg) translateZ(90px);}
    .face:nth-child(5){transform:rotateX(90deg)  translateZ(90px);}
    .face:nth-child(6){transform:rotateX(-90deg) translateZ(90px);}

    .f-name { font-family:'Orbitron',sans-serif; font-size:18px; font-weight:900; letter-spacing:0.06em; color:var(--eng); text-transform:uppercase; line-height:1; margin-bottom:12px; }
    .f-rule { width:24px; height:1px; background:rgba(60,80,180,0.1); margin:0 auto 12px; }
    .f-body { font-family:'Space Mono',monospace; font-size:7.5px; letter-spacing:0.1em; color:var(--dim); line-height:2; font-style:italic; }
    .f-tag  { font-family:'Space Mono',monospace; font-size:6.5px; letter-spacing:0.2em; color:rgba(40,60,180,0.28); margin-top:10px; text-transform:uppercase; border:1px solid rgba(40,60,180,0.1); padding:2px 7px; }

    #heroWrap { position:absolute; inset:0; z-index:10; display:flex; flex-direction:column; align-items:center; justify-content:center; pointer-events:none; }
    .h-name {
      font-family:'Orbitron',sans-serif; font-size:clamp(64px,12vw,144px); font-weight:900;
      letter-spacing:-0.02em; line-height:1;
      background:linear-gradient(170deg,#fff 0%,#e0e0f0 25%,var(--silver) 50%,#606070 80%,#1a1a28 100%);
      -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
      filter:drop-shadow(0 1px 0 #000) drop-shadow(0 3px 0 rgba(0,0,20,.9)) drop-shadow(0 7px 0 rgba(0,0,20,.5)) drop-shadow(0 24px 50px rgba(0,0,0,.98));
    }
    .h-dot { font-family:'Orbitron',sans-serif; font-size:clamp(18px,2.8vw,34px); font-weight:400; color:var(--ghost); letter-spacing:0.22em; margin-top:8px; }
    .h-sub { font-family:'Space Mono',monospace; font-size:clamp(8px,1vw,11px); letter-spacing:0.42em; color:var(--dim); text-transform:uppercase; margin-top:26px; }

    #endWrap { position:absolute; inset:0; z-index:12; display:flex; flex-direction:column; align-items:center; justify-content:center; pointer-events:none; opacity:0; }
    #endWrap .h-name {
      font-size:clamp(82px,16vw,210px);
      background:linear-gradient(165deg,#fff 0%,#e8e8fa 18%,var(--silver) 42%,#707080 72%,#1a1a28 100%);
      -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
      filter:drop-shadow(0 2px 0 #000) drop-shadow(0 5px 0 rgba(0,0,30,.95)) drop-shadow(0 12px 0 rgba(0,0,30,.5)) drop-shadow(0 36px 70px rgba(0,0,0,1));
    }
    #endWrap .h-dot { color:var(--trace); }
    #endWrap .h-sub { margin-top:32px; letter-spacing:0.5em; }

    #cue { position:absolute; bottom:46px; left:50%; transform:translateX(-50%); font-family:'Space Mono',monospace; font-size:8px; letter-spacing:0.5em; color:var(--dim); text-transform:uppercase; pointer-events:none; z-index:6; animation:cue 3s ease-in-out 3s infinite; }
    @keyframes cue { 0%,100%{opacity:0;} 50%{opacity:1;} }

    #phaseLabel { position:absolute; top:50px; left:50%; transform:translateX(-50%); font-family:'Orbitron',sans-serif; font-size:7.5px; letter-spacing:0.5em; color:var(--dim); text-transform:uppercase; opacity:0; transition:opacity 0.7s ease; z-index:6; white-space:nowrap; pointer-events:none; }
    #phaseLabel.on { opacity:1; }

    #pips { position:absolute; right:34px; top:50%; transform:translateY(-50%); display:flex; flex-direction:column; gap:8px; z-index:6; opacity:0; transition:opacity 0.5s; }
    #pips.on { opacity:1; }
    .pip { width:2px; height:2px; border-radius:50%; background:var(--dim); transition:all 0.4s; }
    .pip.lit { background:rgba(80,110,230,0.6); transform:scale(2.5); }

    #mail { position:absolute; width:100%; max-width:440px; text-align:center; opacity:0; pointer-events:none; padding:0 40px; z-index:20; }
    #mail.on { pointer-events:all; }
    .m-title { font-family:'Orbitron',sans-serif; font-size:clamp(22px,4vw,46px); font-weight:700; letter-spacing:-0.01em; margin-bottom:12px; background:linear-gradient(170deg,#fff 0%,var(--silver) 50%,#444456 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; filter:drop-shadow(0 4px 20px rgba(0,0,0,.9)); }
    .m-sub { font-family:'Space Mono',monospace; font-size:clamp(9px,1.2vw,12px); color:var(--eng); line-height:2; margin-bottom:28px; letter-spacing:0.04em; }
    .m-form { display:flex; flex-direction:column; gap:8px; }
    .m-input { width:100%; padding:14px 20px; background:#000; border:1px solid var(--trace); color:#fff; font-family:'Space Mono',monospace; font-size:13px; outline:none; transition:border-color 0.3s; box-shadow:inset 0 0 20px #000; }
    .m-input::placeholder { color:var(--dim); }
    .m-input:focus { border-color:rgba(60,80,180,0.3); }
    .m-btn { padding:14px 20px; background:#000; border:1px solid var(--trace); color:var(--eng); font-family:'Orbitron',sans-serif; font-size:9px; font-weight:700; letter-spacing:0.4em; text-transform:uppercase; cursor:pointer; transition:all 0.3s; }
    .m-btn:hover { border-color:rgba(60,80,180,0.3); color:var(--silver); }
    .m-note { font-size:8px; color:var(--dim); margin-top:12px; letter-spacing:0.1em; }

    footer { position:absolute; bottom:0; left:0; width:100%; padding:22px 48px; opacity:0; pointer-events:none; z-index:8; transition:opacity 0.6s; border-top:1px solid var(--trace); background:linear-gradient(0deg,#000 0%,transparent 100%); }
    footer.on { opacity:1; pointer-events:all; }
    .fg { display:grid; grid-template-columns:repeat(auto-fit,minmax(140px,1fr)); gap:24px; max-width:860px; margin:0 auto; }
    .fs { opacity:0; }
    footer.on .fs:nth-child(1){animation:rise .6s ease .05s forwards;}
    footer.on .fs:nth-child(2){animation:rise .6s ease .15s forwards;}
    footer.on .fs:nth-child(3){animation:rise .6s ease .25s forwards;}
    @keyframes rise { from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);} }
    .fs h4 { font-family:'Orbitron',sans-serif; font-size:7px; letter-spacing:0.4em; color:var(--dim); text-transform:uppercase; margin-bottom:10px; font-weight:700; }
    .fs p  { font-family:'Space Mono',monospace; font-size:10px; line-height:2.2; color:var(--dim); }

    @media(max-width:700px){
      .face{padding:16px;} .f-name{font-size:14px;} #pips{right:10px;}
      .fg{grid-template-columns:1fr;text-align:center;}
      .edge{left:18px;right:18px;}
    }
  </style>
</head>
<body>

<div id="scroller">
  <div id="spacer">
    <div id="stage">
      <canvas id="atmos"></canvas>

      <div class="edge top"></div>
      <div class="edge bottom"></div>
      <div class="corner tl"></div><div class="corner tr"></div>
      <div class="corner bl"></div><div class="corner br"></div>

      <div class="onyx-stage">
        <div class="onyx-cube breathing" id="cube">
          <div class="face"><div class="f-name">BeOnyx</div><div class="f-rule"></div><div class="f-body" style="font-style:normal;letter-spacing:.18em;font-size:7px;color:var(--dim);">beonyx.dev</div></div>
          <div class="face"><div class="f-name">NyxOS</div><div class="f-rule"></div><div class="f-body">Before the sun.<br>After the sun.<br>She was always there.</div><div class="f-tag">In Development</div></div>
          <div class="face"><div class="f-name">Nullbox</div><div class="f-rule"></div><div class="f-body">"When you thought<br>hallucinations were<br>a bad thing."</div><div class="f-tag">In Development</div></div>
          <div class="face"><div class="f-name">Antonius</div><div class="f-rule"></div><div class="f-body">...and all you<br>gotta say is<br>"Sup"</div><div class="f-tag">Coming Soon</div></div>
          <div class="face"><div class="f-name" style="font-size:15px;">Onyx<br>Core</div><div class="f-rule"></div><div class="f-body" style="font-style:normal;">The foundation.<br>Everything runs on it.</div><div class="f-tag">Coming Soon</div></div>
          <div class="face"><div class="f-name" style="font-size:28px;color:var(--dim);margin-bottom:6px;">2025</div><div class="f-body" style="font-style:normal;letter-spacing:.22em;font-size:6.5px;">BEONYX.DEV</div></div>
        </div>
      </div>

      <div id="heroWrap">
        <span class="h-name">BeOnyx</span>
        <span class="h-dot">.dev</span>
        <span class="h-sub">Building in the dark</span>
      </div>

      <div id="endWrap">
        <span class="h-name">BeOnyx</span>
        <span class="h-dot" style="opacity:0;">.dev</span>
        <span class="h-sub" style="opacity:0;">Building in the dark</span>
      </div>

      <div id="cue">Scroll</div>
      <div id="phaseLabel"></div>
      <div id="pips"><div class="pip"></div><div class="pip"></div><div class="pip"></div><div class="pip"></div><div class="pip"></div></div>

      <div id="mail">
        <h2 class="m-title">Stay close.</h2>
        <p class="m-sub">Drop your email.<br>You'll hear something when it matters.</p>
        <form class="m-form" id="mailForm">
          <input type="email" placeholder="you@wherever.com" class="m-input" required>
          <button type="submit" class="m-btn"><span id="btnTxt">In</span></button>
        </form>
        <p class="m-note">No noise.</p>
      </div>

      <footer id="footer">
        <div class="fg">
          <div class="fs"><h4>BeOnyx.dev</h4><p>Built quietly.<br>Shipped when ready.</p></div>
          <div class="fs"><h4>Projects</h4><p>NyxOS<br>Nullbox<br>Antonius<br>Onyx Core</p></div>
          <div class="fs"><h4>Contact</h4><p>forge@beonyx.dev</p></div>
        </div>
      </footer>
    </div>
  </div>
</div>

<script>
// ── NEBULA ──
(function(){
  const cv=document.getElementById('atmos'),ctx=cv.getContext('2d');
  let W,H;
  const blobs=[
    {x:.28,y:.38,r:.52,vx:.00011, vy:.00007, h:230,s:70,l:8, a:.5 },
    {x:.72,y:.62,r:.44,vx:-.00009,vy:-.00006,h:220,s:65,l:6, a:.42},
    {x:.50,y:.82,r:.28,vx:.00006, vy:.00010, h:240,s:80,l:5, a:.3 },
  ];
  function resize(){W=cv.width=cv.offsetWidth;H=cv.height=cv.offsetHeight;}
  function frame(){
    ctx.clearRect(0,0,W,H);
    blobs.forEach(b=>{
      b.x+=b.vx;b.y+=b.vy;
      if(b.x<.1||b.x>.9)b.vx*=-1;
      if(b.y<.1||b.y>.9)b.vy*=-1;
      const cx=b.x*W,cy=b.y*H,r=b.r*Math.min(W,H);
      const g=ctx.createRadialGradient(cx,cy,0,cx,cy,r);
      g.addColorStop(0,  `hsla(${b.h},${b.s}%,${b.l}%,${b.a})`);
      g.addColorStop(.45,`hsla(${b.h},${b.s}%,${b.l-2}%,${b.a*.38})`);
      g.addColorStop(1,  `hsla(${b.h},${b.s}%,${b.l}%,0)`);
      ctx.beginPath();ctx.arc(cx,cy,r,0,Math.PI*2);ctx.fillStyle=g;ctx.fill();
    });
    requestAnimationFrame(frame);
  }
  resize();frame();
  window.addEventListener('resize',resize);
})();

// ── ENGINE ──
const scroller=document.getElementById('scroller');
const spacer  =document.getElementById('spacer');
const cube    =document.getElementById('cube');
const heroWrap=document.getElementById('heroWrap');
const endWrap =document.getElementById('endWrap');
const mail    =document.getElementById('mail');
const footer  =document.getElementById('footer');
const label   =document.getElementById('phaseLabel');
const pipsEl  =document.getElementById('pips');
const pips    =pipsEl.querySelectorAll('.pip');
const cue     =document.getElementById('cue');

function resize(){ spacer.style.height=(window.innerHeight*7)+'px'; }
resize(); window.addEventListener('resize',resize);

const phases=[
  {name:'BEONYX',   s:0,   e:.11},
  {name:'NYXOS',    s:.11, e:.25},
  {name:'NULLBOX',  s:.25, e:.39},
  {name:'ANTONIUS', s:.39, e:.53},
  {name:'ONYX CORE',s:.53, e:.67},
];

const MAIL_S=.57,MAIL_E=.72,FADE_S=.72,FADE_E=.84,END_S=.80,END_E=.94;

const clamp=(v,a,b)=>Math.max(a,Math.min(b,v));
const ease =t=>t*t*(3-2*t);
const lerp =(a,b,t)=>a+(b-a)*t;
function easeOutExpo(t){return t>=1?1:1-Math.pow(2,-10*t);}

let scrolled=false,ticking=false;

function update(){
  const max=scroller.scrollHeight-scroller.clientHeight;
  const p=max>0?clamp(scroller.scrollTop/max,0,1):0;

  if(scroller.scrollTop>8&&!scrolled){
    scrolled=true;
    cube.classList.remove('breathing');
    cue.style.animation='none';cue.style.opacity='0';
  }else if(scroller.scrollTop<=8&&scrolled){
    scrolled=false;
    cube.classList.add('breathing');
    cube.style.transform='';cube.style.opacity='1';
    cue.style.animation='';cue.style.opacity='';
  }

  // Cube
  if(scrolled){
    let sc,ry,rx,op;
    if(p<=MAIL_E){
      const t=p/MAIL_E;
      sc=1+t*2.8;ry=t*540;rx=t*22;op=1;
    }else{
      const fe=clamp((p-FADE_S)/(FADE_E-FADE_S),0,1);
      sc=lerp(3.8,.6,ease(fe));ry=lerp(540,620,fe);rx=lerp(22,0,fe);op=1-ease(fe);
    }
    cube.style.transform=`scale(${sc.toFixed(3)}) rotateX(${rx.toFixed(2)}deg) rotateY(${ry.toFixed(2)}deg)`;
    cube.style.opacity=op.toFixed(3);
  }

  // Intro hero
  heroWrap.style.opacity=(1-ease(clamp(p/.14,0,1))).toFixed(3);

  // End title
  if(p>=END_S){
    const t=clamp((p-END_S)/(END_E-END_S),0,1);
    const prog=easeOutExpo(t);
    endWrap.style.opacity=Math.min(1,t/.4).toFixed(3);
    endWrap.style.transform=`scale(${lerp(.9,1,prog).toFixed(4)})`;
    endWrap.querySelector('.h-name').style.letterSpacing=lerp(-.04,-.02,prog).toFixed(3)+'em';
    endWrap.querySelector('.h-dot').style.opacity=clamp((t-.3)/.3,0,1).toFixed(3);
    endWrap.querySelector('.h-sub').style.opacity=clamp((t-.55)/.3,0,1).toFixed(3);
  }else{
    endWrap.style.opacity='0';
    endWrap.style.transform='scale(0.9)';
    endWrap.querySelector('.h-name').style.letterSpacing='-.04em';
    endWrap.querySelector('.h-dot').style.opacity='0';
    endWrap.querySelector('.h-sub').style.opacity='0';
  }

  // Phase nav
  const showNav=p>.04&&p<MAIL_E+.02;
  pipsEl.classList.toggle('on',showNav);
  const pi=phases.findIndex(ph=>p>=ph.s&&p<ph.e);
  pips.forEach((d,i)=>d.classList.toggle('lit',i===pi));
  label.textContent=(showNav&&pi>=0)?phases[pi].name:'';
  label.classList.toggle('on',showNav&&pi>=0);

  // Mailing
  if(p>=MAIL_S&&p<MAIL_E){
    mail.style.opacity=ease(clamp((p-MAIL_S)/.06,0,1)).toFixed(3);
    mail.classList.add('on');
  }else if(p>=MAIL_E&&p<FADE_E){
    mail.style.opacity=(1-ease(clamp((p-MAIL_E)/.05,0,1))).toFixed(3);
    if(parseFloat(mail.style.opacity)<=.01)mail.classList.remove('on');
  }else{
    mail.style.opacity='0';mail.classList.remove('on');
  }

  footer.classList.toggle('on',p>.96);
}

scroller.addEventListener('scroll',()=>{
  if(!ticking){
    requestAnimationFrame(()=>{update();ticking=false;});
    ticking=true;
  }
},{passive:true});

document.getElementById('mailForm').addEventListener('submit',e=>{
  e.preventDefault();
  const btn=document.getElementById('btnTxt');
  const input=e.target.querySelector('.m-input');
  btn.textContent='...';
  setTimeout(()=>{btn.textContent='Done';input.value='';setTimeout(()=>{btn.textContent='In';},2200);},1100);
});

update();
</script>
</body>
</html>
